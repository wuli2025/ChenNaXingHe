{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChenNaXingHe",
  "mainBinaryName": "ChenNaXingHe",
  "version": "1.8.0",
  "identifier": "com.chennaxinghe.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "陈娜星河 · ChenNaXingHe",
        "width": 1500,
        "height": 960,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "maximized": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost https:; font-src 'self' data: https:; connect-src 'self' ipc: http://ipc.localhost ws: wss: https:; frame-src 'self' data: blob:; object-src 'none'; base-uri 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://gh-proxy.com/https://github.com/wuli2025/ChenNaXingHe/releases/latest/download/latest.json",
        "https://github.com/wuli2025/ChenNaXingHe/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxMDg0NDQ4RkVBMTc0MUMKUldRY2RLSCtTRVFJOGMrYWFvNHY5TTRJWk9Bb1R3aEh0OTlJZEk5dHNJNEJTVFRXcFJ0N1JMNWwK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "本地优先 AI 工作台",
    "longDescription": "陈娜星河(ChenNaXingHe) 是一个本地优先的 AI 工作台,集成 Claude Code 对话、维基知识库和跨境电商模块。",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both",
        "compression": "lzma",
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  }
}
